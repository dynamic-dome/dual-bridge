# =====================================================================
#  DCO STAGING-Instanz (.env.staging)  —  Idee 4 / Dual-Bridge
#  Läuft AUF LAPTOP B, isoliert gegen die Prod-DCO-Instanz.
#  ---------------------------------------------------------------
#  Dies ist ein TEMPLATE mit Platzhaltern. NIEMALS echte Secrets
#  ins Sharepoint oder ins Git-Repo committen (Manifest §6/§7).
#  Auf B: kopieren nach  AI\dual-bridge\staging\.env.staging  und
#  ausfüllen. (Das Start-Skript liest die Datei aus $PSScriptRoot,
#  also NEBEN start_staging_dco.ps1 — NICHT ins DCO-Repo legen.)
# =====================================================================

# --- ISOLATION: eigener Daten-Ordner (Pflicht für Idee 4) -----------
# Trennt die meisten DBs (jobs/calls/artifacts/...) von der Prod-Instanz.
# config.py:133-135 liest das lazy; der Ordner wird auto-angelegt.
DCO_DATA_DIR_OVERRIDE=./data_staging

# --- ISOLATION 2: agent_runs liegt NICHT unter DATA_DIR! ------------
# agent_run.py:24 / agent_registry.py:14 lesen einen EIGENEN Pfad aus
# DCO_AGENT_RUN_ROOT (Default: ./data/agent_runs). OHNE diese Zeile
# schreiben Staging-Agent-Runs in PROD-data/agent_runs. Pflicht!
DCO_AGENT_RUN_ROOT=./data_staging/agent_runs

# --- TELEGRAM: ZWEITER Bot (vom User via @BotFather) ----------------
# Eigener Bot, damit Prod- und Staging-Bot sich nicht überlappen.
# Chat-ID kann dieselbe bleiben (8630776278) oder ein eigener Test-Chat.
TELEGRAM_TOKEN=<STAGING_BOT_TOKEN_VON_BOTFATHER>
TELEGRAM_CHAT_ID=8630776278

# --- PFLICHT-SECRETS (sonst RuntimeError beim Start, config.py) ------
# MÜSSEN gesetzt UND paarweise verschieden sein. Eigene Staging-Werte,
# NICHT die Prod-Secrets kopieren. Generieren:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
WEBHOOK_SECRET=<STAGING_WEBHOOK_SECRET>
ADMIN_PIN=<STAGING_ADMIN_PIN_min8>

# --- OPTIONAL (nur falls auf Staging gebraucht) ---------------------
# Wenn gesetzt: müssen sich von WEBHOOK_SECRET/ADMIN_PIN unterscheiden.
# LOGS_API_TOKEN=<STAGING_LOGS_TOKEN>
# DASHBOARD_TOKEN=<STAGING_DASHBOARD_min16>

# --- ERB-FALLE: load_dotenv() ohne Arg lädt zusätzlich Prod-.env ----
# python-dotenv override=False → explizit hier gesetzte Keys gewinnen,
# WEGGELASSENE Keys erben aus der Prod-.env auf B (config.py:7). Wenn
# Staging diese NICHT erben soll, hier explizit leeren/eigenen Wert setzen:
NOTEBOOKLM_NOTEBOOK_ID=
# PUBLIC_BASE_URL=
# WIKI_INBOX_DIR=

# --- LLM-Bridges (nur falls Staging echte duett/agent-Calls macht) --
# ACHTUNG (Memory L: DCO brain.py API-Key-Leak): ANTHROPIC_API_KEY hier
# führt zu API-Billing statt Abo, wenn der claude-CLI-Subprozess ihn erbt.
# Für reines Staging gegen die isolierte DB i.d.R. NICHT setzen.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...

# --- KEIN Port hier ---
# Port 8000 ist in tray.pyw hardcoded; Staging startet NICHT über die
# Tray-App (Single-Instance-Mutex "ClaudeZentraleTray" + Port-Fix).
# Staging-Start = direkter uvicorn auf Port 8001, siehe START-Sequenz.
