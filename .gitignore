# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Agentic-OS session memory (per-machine state, never shared)
.agent-memory/
scripts/.agent-memory/

# Real secrets — only the .template is tracked
.env
.env.*
!.env*.template

# Codex working clones (Stage 1 workroot, per-machine)
dual-bridge-work/
*.codex-answer-*.txt

# loop history + working clones (per-machine, never committed)
scripts/state/

# Local poller lock
*.lock

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

# One-off drive-cleanup backups (test-leak incident 2026-06-02), never shared
.drive-cleanup-backup-*/
